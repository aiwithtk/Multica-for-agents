# ==============================================================================
# Configuration pour les agents YouTube (Reader, Writer, Responder)
# ==============================================================================

# Clé API Google/YouTube pour la lecture (Data API v3)
YOUTUBE_API_KEY=VOTRE_CLE_API_ICI

# ID de votre chaîne YouTube (utilisé pour identifier les commentaires "ME" 
# et cibler la chaîne lors du postage)
YOUTUBE_CHANNEL_ID=VOTRE_CHANNEL_ID_ICI

# Chemins optionnels pour l'authentification OAuth (youtube-writer)
# Si non spécifié, cherchera dans le répertoire d'exécution.
YOUTUBE_CLIENT_SECRETS_PATH=client_secrets.json
YOUTUBE_TOKEN_PICKLE_PATH=token.pickle

# Autres clés potentielles (si vous utilisez LLM/Anthropic pour youtube-responder)
# ANTHROPIC_API_KEY=VOTRE_CLE_ANTHROPIC_ICI
# OPENAI_API_KEY=VOTRE_CLE_OPENAI_ICI
